# PRANU v2 — Environment Configuration

# Server
PORT=4000
WS_PORT=4001
NODE_ENV=development

# LLM API Keys (set at least one)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

TOGETHER_API_KEY=
TOGETHER_MODEL=deepseek-ai/DeepSeek-V3
TOGETHER_BASE_URL=https://api.together.xyz/v1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Docker Sandbox
SANDBOX_ENABLED=false
SANDBOX_IMAGE=pranu-sandbox:latest
SANDBOX_CPU_LIMIT=2
SANDBOX_MEMORY_LIMIT=4g
SANDBOX_TIMEOUT_MS=300000

# Workspace
WORKSPACE_PATH=/tmp/pranu-workspace

# Database
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./data/pranu.db

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key
JWT_REFRESH_EXPIRES_IN=30d
FRONTEND_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:4000/api/v1/auth/oauth/google/callback

# S3 Storage
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
